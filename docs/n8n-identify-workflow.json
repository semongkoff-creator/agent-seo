    {
      "parameters": {
        "jsCode": "// Extract & normalize payload from any BE format (camelCase OR snake_case)\nconst raw = $input.first().json;\nconst body = raw.body ?? raw;\n\nconst pick = (...vals) => vals.find(v => v !== undefined && v !== null && v !== '') ?? null;\n\nconst identify_merged = pick(\n  body.identify_merged,\n  body.identifyMerged,\n  body.payload?.identify_merged,\n  body.payload?.identifyMerged,\n  body.payload?.identify?.merged,\n  body.identify?.merged\n) ?? {};\n\nconst identify_drafts = pick(\n  body.identify_drafts,\n  body.identifyDrafts,\n  body.payload?.identify_drafts,\n  body.payload?.identifyDrafts,\n  body.payload?.identify?.drafts,\n  body.identify?.drafts\n) ?? [];\n\nconst job_id = pick(\n  body.job_id, body.jobId,\n  body.payload?.job_id, body.payload?.jobId,\n  body.payload?.job?.id\n);\n\nconst project_id = pick(\n  body.project_id, body.projectId,\n  body.payload?.project_id, body.payload?.projectId,\n  body.payload?.project?.id\n);\n\nconst user_id = pick(\n  body.user_id, body.userId,\n  body.payload?.user_id, body.payload?.userId,\n  body.payload?.user?.id\n);\n\nconst diagnosis_id = pick(\n  body.diagnosis_id, body.diagnosisId,\n  body.payload?.diagnosis_id, body.payload?.diagnosisId,\n  body.payload?.diagnosis?.id\n);\n\nif (!job_id || !project_id || !diagnosis_id) {\n  throw new Error(`Missing required IDs. job_id=${job_id}, project_id=${project_id}, diagnosis_id=${diagnosis_id}`);\n}\n\nreturn [{\n  json: {\n    job_id,\n    project_id,\n    user_id,\n    diagnosis_id,\n    identify_drafts,\n    identify_merged,\n    action: pick(body.action, body.payload?.action) ?? 'identify_problem'\n  }\n}];"
      },
