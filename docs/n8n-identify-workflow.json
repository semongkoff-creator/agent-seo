    {
      "parameters": {
        "description": "Computes derived SEO signals from the brief.",
        "jsCode": "const raw = typeof query === 'string' ? query : JSON.stringify(query ?? {});\nlet parsed;\ntry { parsed = JSON.parse(raw); } catch { parsed = { raw }; }\n\nconst brief = parsed.brief ?? parsed;\n\nconst indexedRatio = brief.indexed_pages != null && brief.published_pages\n  ? Math.round((brief.indexed_pages / brief.published_pages) * 100) : null;\nconst drGap = brief.competitor_dr_avg != null && brief.domain_rating != null\n  ? brief.competitor_dr_avg - brief.domain_rating : null;\nconst techIssues = [\n  brief.has_redirect_errors, brief.has_4xx_5xx_errors,\n  brief.canonical_issues, brief.noindex_issues,\n  brief.mobile_usability_issues, brief.core_web_vitals_pass === false\n].filter(Boolean).length;\nconst rankingKwCount = Array.isArray(brief.current_ranking_keywords)\n  ? brief.current_ranking_keywords.length : (brief.current_ranking_keywords ?? 0);\nconst targetKwCount = Array.isArray(brief.target_keywords) ? brief.target_keywords.length : 0;\n\nreturn JSON.stringify({\n  signals: {\n    indexed_ratio_percent: indexedRatio,\n    domain_rating_gap_vs_competitors: drGap,\n    technical_issues_count: techIssues,\n    ranking_keywords_count: rankingKwCount,\n    target_keywords_count: targetKwCount,\n    has_organic_traffic: (brief.monthly_organic_traffic ?? 0) > 0,\n    conversion_rate_low: brief.current_conversion_rate != null && brief.current_conversion_rate < 1.0,\n    bounce_rate_high: brief.bounce_rate != null && brief.bounce_rate > 70\n  },\n  stage: brief.website_stage ?? null,\n  user_concern: brief.main_seo_concern ?? null\n});"
      },
      "id": "6aab14b5-9f0c-4a18-a5bb-7382f74e7956",
      "name": "SEO Signals Tool",
      "type": "@n8n/n8n-nodes-langchain.toolCode",
      "typeVersion": 1.3,
      "position": [
        1248,
        1232
      ]
    },
    {
      "parameters": {
        "jsCode": "// Extract flow data from before AI Agent (because AI Agent overwrites json)\nconst flow = $('Verify HMAC (DEV)').first().json;\nconst aiOutput = $input.first().json;\n\nlet raw = aiOutput.output ?? aiOutput.text ?? aiOutput.response ?? aiOutput.result ?? aiOutput;\nlet parsed = raw;\n\nif (typeof raw === 'string') {\n  const cleaned = raw.replace(/^```json\\s*/i, '').replace(/^```\\s*/i, '').replace(/\\s*```$/i, '').trim();\n  try { parsed = JSON.parse(cleaned); } catch { parsed = null; }\n}\n\nconst VALID_PROBLEMS = ['technical_bottleneck', 'relevance_gap', 'authority_deficit', 'conversion_pitfall', 'from_scratch', 'mixed'];\nconst VALID_SEVERITY = ['low', 'medium', 'high', 'critical'];\nconst VALID_READINESS = ['ready', 'not_ready', 'partially_ready'];\nconst VALID_DIRECTIONS = ['technical_recovery', 'qualified_traffic', 'authority_growth', 'conversion_improvement', 'foundation_building', 'mixed'];\n\nif (!parsed || typeof parsed !== 'object') {\n  parsed = {\n    primary_problem_type: 'mixed',\n    secondary_problem_type: null,\n    severity: 'medium',\n    confidence_score: 50,\n    diagnosis_summary: 'AI output could not be parsed.',\n    root_cause: 'The AI response was not valid JSON.',\n    evidence: [],\n    business_impact: { summary: '', metrics: [] },\n    campaign_readiness: 'partially_ready',\n    recommended_next_step: 'Retry diagnosis.',\n    objective_direction: 'mixed',\n    not_recommended_actions: [],\n    warnings: ['AI output was not valid JSON'],\n    raw_llm_output: { text: String(raw).slice(0, 2000) },\n    model_used: 'gpt-4o-mini'\n  };\n} else {\n  if (!VALID_PROBLEMS.includes(parsed.primary_problem_type)) parsed.primary_problem_type = 'mixed';\n  if (parsed.secondary_problem_type !== null && !VALID_PROBLEMS.includes(parsed.secondary_problem_type)) parsed.secondary_problem_type = null;\n  if (!VALID_SEVERITY.includes(parsed.severity)) parsed.severity = 'medium';\n  if (!VALID_READINESS.includes(parsed.campaign_readiness)) parsed.campaign_readiness = 'partially_ready';\n  if (!VALID_DIRECTIONS.includes(parsed.objective_direction)) parsed.objective_direction = 'mixed';\n  if (typeof parsed.confidence_score !== 'number') parsed.confidence_score = 60;\n  if (!Array.isArray(parsed.evidence)) parsed.evidence = [];\n  if (!Array.isArray(parsed.not_recommended_actions)) parsed.not_recommended_actions = [];\n  if (!Array.isArray(parsed.warnings)) parsed.warnings = [];\n  if (!parsed.business_impact || typeof parsed.business_impact !== 'object') parsed.business_impact = { summary: '', metrics: [] };\n  if (!Array.isArray(parsed.business_impact.metrics)) parsed.business_impact.metrics = [];\n  if (!parsed.model_used) parsed.model_used = 'gpt-4o-mini';\n  if (!parsed.raw_llm_output) parsed.raw_llm_output = {};\n  if (!parsed.diagnosis_summary) parsed.diagnosis_summary = '';\n  if (!parsed.root_cause) parsed.root_cause = '';\n  if (!parsed.recommended_next_step) parsed.recommended_next_step = '';\n}\n\nconst now = new Date().toISOString();\n\nreturn [{\n  json: {\n    job_id: flow.job_id,\n    project_id: flow.project_id,\n    user_id: flow.user_id,\n    diagnosis_id: flow.diagnosis_id,\n    completed_at: now,\n    // Flattened fields for Supabase update\n    primary_problem_type: parsed.primary_problem_type,\n    secondary_problem_type: parsed.secondary_problem_type,\n    severity: parsed.severity,\n    confidence_score: parsed.confidence_score,\n    diagnosis_summary: parsed.diagnosis_summary,\n    root_cause: parsed.root_cause,\n    evidence: parsed.evidence,\n    business_impact: parsed.business_impact,\n    campaign_readiness: parsed.campaign_readiness,\n    recommended_next_step: parsed.recommended_next_step,\n    objective_direction: parsed.objective_direction,\n    not_recommended_actions: parsed.not_recommended_actions,\n    warnings: parsed.warnings,\n    raw_llm_output: parsed.raw_llm_output,\n    model_used: parsed.model_used,\n    // Full result for response_payload in jobs table\n    diagnosis_result: parsed\n  }\n}];"
      },
